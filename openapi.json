  "components": {
    "schemas": {
      "TrackEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "track",
              "identify",
              "page",
              "screen",
              "group",
              "alias"
            ]
